# ============================================
# CineAI - Environment Variables
# ============================================
# Copia este archivo como .env y rellena los valores.
# NUNCA subas .env a Git.

# --- PostgreSQL ---
POSTGRES_USER=cineai
POSTGRES_PASSWORD=cineai_secret_2024
POSTGRES_DB=cineai_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://cineai:cineai_secret_2024@db:5432/cineai_db

# --- Backend API ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info
LLM_SERVICE_URL=http://llm_service:8001

# --- LLM Service ---
LLM_HOST=0.0.0.0
LLM_PORT=8001
GEMINI_API_KEY=your_gemini_api_key_here

# --- TMDB (solo para seeding) ---
TMDB_API_KEY=your_tmdb_api_key_here

# --- Frontend (build-time) ---
VITE_API_URL=http://localhost:8000
